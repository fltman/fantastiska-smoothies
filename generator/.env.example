# Mall för generator/.env — kopiera filen och fyll i värdena:
#     cp generator/.env.example generator/.env
# generator/.env är gitignorerad, laddas aldrig upp till webben och nämns aldrig
# i någon annan fil. Här i exemplet står aldrig ett riktigt värde.

# ── Brevlådan ───────────────────────────────────────────────────────────────
# Brevlådan som tar emot önskemål, t.ex. smoothies@bjarby.com
SMOOTHIE_EPOST=
# Lösenordet till brevlådan hos one.com (IMAP imap.one.com:993, SMTP send.one.com:465)
SMOOTHIE_EPOST_LOSENORD=
# Hemlig sträng som saltar hashen av avsändaradressen i onskemal.json. Sätt ett
# eget långt slumpvärde innan sajten går publik — adressen lagras aldrig i klartext.
SMOOTHIE_SALT=

# ── Modellerna ──────────────────────────────────────────────────────────────
# API-nyckel till OpenRouter — recept.py skriver recepten och bild.py bilderna
OPENROUTER_API_KEY=
# Modell som skriver recepten. Lämna tom för generatorns standardval.
SMOOTHIE_MODELL=
# Sökväg till bildskriptet (gemini-imagegen). Lämna tom för standardplatsen.
SMOOTHIE_BILDSKRIPT=
# Sekunder innan bildgenereringen ger upp. Lämna tom för 300.
SMOOTHIE_BILD_TIMEOUT=
# Sökväg till cwebp om den inte ligger i PATH (brew install webp). Lämna tom annars.
SMOOTHIE_CWEBP=

# ── Takten ──────────────────────────────────────────────────────────────────
# Så många timmar sajten måste ha stått still innan huset brygger en egen
# smoothie. Lämna tom för 24. Sätt 0 för att stänga av husets egen helt — då
# växer sajten bara på inkomna önskemål. Mailkollen berörs inte av det här.
HUSETS_EGEN_TIMMAR=

# ── Uppladdningen ───────────────────────────────────────────────────────────
# SFTP-värd hos one.com, t.ex. ssh.bjarby.com
SFTP_HOST=
# SFTP-användare hos one.com
SFTP_ANVANDARE=
# SFTP-lösenord — lämna tomt om inloggningen sker med ssh-nyckel
SFTP_LOSENORD=
# Mappen på servern som site/ speglas till, t.ex. httpd.www
SFTP_MAPP=
# SFTP-port — lämna tom för 22
SFTP_PORT=
# Sajtens adress utan avslutande snedstreck, används i länken i svarsmailet
SAJT_URL=
